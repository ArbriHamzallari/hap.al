# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=generate-a-random-32-char-string
TELEGRAM_WEBHOOK_URL=https://hapal-production.up.railway.app/webhook

# === LLM ===
ANTHROPIC_API_KEY=your-anthropic-key
DEFAULT_LLM_MODEL=claude-haiku-4-5-20251001
ANALYSIS_LLM_MODEL=claude-sonnet-4-6

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key  # post-MVP Mini App only; backend uses SERVICE_KEY

# === Security ===
ENCRYPTION_KEY=generate-with-python-see-below
TELEGRAM_ID_HASH_SALT=generate-a-random-string
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_DAY=200
LLM_DAILY_CALL_LIMIT=50
MONTHLY_BUDGET_CAP_USD=50

# === Internal cron (pg_cron → /internal/process-followups) ===
INTERNAL_CRON_SECRET=generate-a-random-32-char-string

# === Logging ===
LOG_LEVEL=INFO
SENTRY_DSN=  # paste DSN from your Sentry FastAPI project; leave empty to disable

# === App ===
# Local dev: APP_ENV=development, USE_POLLING=true
# Production (Railway): APP_ENV=production, USE_POLLING=false
APP_ENV=development
APP_PORT=8000
USE_POLLING=true
