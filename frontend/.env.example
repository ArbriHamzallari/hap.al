# Vite exposes only VITE_-prefixed vars to the client. Never put secrets here.

# Telegram bot deeplink — the CTA on the landing page opens this URL.
VITE_TELEGRAM_BOT_URL=https://t.me/hap_bot

# Sentry (optional). Create a separate Sentry project of platform "React" for
# the frontend — do NOT reuse the backend FastAPI DSN.
VITE_SENTRY_DSN=
